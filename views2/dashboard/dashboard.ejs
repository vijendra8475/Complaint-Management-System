                    <span class="material-symbols-outlined text-[18px]">phone_in_talk</span>
                    Emergency Hotline
                </button>
                <a class="flex items-center gap-3 px-4 py-2 text-on-surface-variant hover:bg-surface-container-low transition-all"
                    href="#">
                    <span class="material-symbols-outlined">settings</span>
                    <span class="text-body-md">Settings</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-2 text-on-surface-variant hover:bg-surface-container-low transition-all"
                    href="#">
                    <span class="material-symbols-outlined">logout</span>
                    <span class="text-body-md">Logout</span>
                </a>
            </div>
        </aside>
        <!-- Main Content Wrapper -->
