                        <input
                            class="w-full bg-surface-container-low border-none rounded-full pl-10 pr-4 py-2 text-body-md focus:ring-1 focus:ring-primary"
                            placeholder="Search complaints, IDs, or categories..." type="text" />
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <button
                        class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface-container-high transition-colors text-on-surface-variant relative">
                        <span class="material-symbols-outlined">notifications</span>
                        <span class="absolute top-2 right-2 w-2 h-2 bg-error rounded-full border border-surface"></span>
                    </button>
                    <button
                        class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface-container-high transition-colors text-on-surface-variant">
                        <span class="material-symbols-outlined">help_outline</span>
