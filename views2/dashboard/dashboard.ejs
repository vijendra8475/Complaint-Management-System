            <div class="px-6 mb-10 flex items-center gap-3">
                <div class="w-10 h-10 bg-primary flex items-center justify-center rounded">
                    <span class="material-symbols-outlined text-on-primary">gavel</span>
                </div>
                <div>
                    <h1 class="text-headline-lg font-black text-primary">CivicResolve</h1>
                    <p class="text-label-md text-on-surface-variant">GovTech Portal</p>
                </div>
            </div>
            <nav class="flex-1 px-4 space-y-1">
                <a class="flex items-center gap-3 px-4 py-3 bg-surface-container text-primary border-l-4 border-primary font-semibold translate-x-1 transition-transform duration-200"
                    href="#">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span class="text-body-md">Dashboard</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-low transition-all"
                    href="#">
                    <span class="material-symbols-outlined">add_box</span>
                    <span class="text-body-md">New Complaint</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-low transition-all"
                    href="#">
                    <span class="material-symbols-outlined">list_alt</span>
                    <span class="text-body-md">My Complaints</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-low transition-all"
                    href="#">
                    <span class="material-symbols-outlined">insights</span>
                    <span class="text-body-md">Analytics</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-low transition-all"
                    href="#">
                    <span class="material-symbols-outlined">description</span>
                    <span class="text-body-md">Reports</span>
                </a>
            </nav>
            <div class="px-4 py-6 border-t border-outline-variant space-y-1">
