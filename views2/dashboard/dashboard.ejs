                                <div
                                    class="absolute -top-8 left-1/2 -translate-x-1/2 bg-primary text-on-primary text-[10px] px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity">
                                    155</div>
                            </div>
                            <div
                                class="flex-1 bg-surface-container-high hover:bg-primary transition-colors h-[95%] rounded-t-sm group relative border-x-2 border-primary border-t-2">
