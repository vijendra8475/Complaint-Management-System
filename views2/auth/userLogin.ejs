<!DOCTYPE html>

<html class="light" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Login | CivicResolve</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "surface-dim": "#ddd9d8",
                        "secondary-fixed-dim": "#c8c6c6",
                        "surface-container-highest": "#e5e2e1",
                        "on-error": "#ffffff",
                        "tertiary": "#000000",
                        "on-secondary": "#ffffff",
                        "on-primary-container": "#858383",
                        "on-surface-variant": "#444748",
                        "on-background": "#1c1b1b",
                        "surface-container-high": "#ebe7e6",
                        "primary-container": "#1c1b1b",
                        "secondary-container": "#e4e2e2",
                        "outline-variant": "#c4c7c7",
                        "on-primary-fixed-variant": "#474746",
                        "surface": "#fdf8f8",
                        "primary-fixed-dim": "#c8c6c5",
                        "on-secondary-container": "#646464",
                        "inverse-surface": "#313030",
                        "surface-container": "#f1edec",
                        "on-primary": "#ffffff",
                        "on-tertiary-container": "#868382",
                        "on-secondary-fixed": "#1b1c1c",
                        "on-surface": "#1c1b1b",
                        "inverse-primary": "#c8c6c5",
                        "secondary-fixed": "#e4e2e2",
                        "surface-container-lowest": "#ffffff",
                        "secondary": "#5e5e5e",
                        "tertiary-fixed-dim": "#cac6c4",
                        "error": "#ba1a1a",
                        "primary": "#000000",
                        "surface-tint": "#5f5e5e",
                        "inverse-on-surface": "#f4f0ef",
                        "error-container": "#ffdad6",
                        "surface-bright": "#fdf8f8",
                        "on-tertiary-fixed-variant": "#484645",
                        "on-tertiary-fixed": "#1c1b1a",
                        "tertiary-fixed": "#e6e2df",
                        "outline": "#747878",
                        "surface-variant": "#e5e2e1",
                        "background": "#fdf8f8",
                        "tertiary-container": "#1c1b1a",
                        "on-primary-fixed": "#1c1b1b",
                        "on-tertiary": "#ffffff",
                        "on-error-container": "#93000a",
                        "surface-container-low": "#f7f3f2",
                        "primary-fixed": "#e5e2e1",
                        "on-secondary-fixed-variant": "#474747"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "16px",
                        "full": "9999px"
                    },
                    "spacing": {
                        "stack-lg": "2rem",
                        "container-max": "1440px",
                        "stack-md": "1rem",
                        "margin-desktop": "2rem",
                        "stack-sm": "0.5rem",
                        "stack-xs": "0.25rem",
                        "gutter": "1.5rem",
                        "margin-mobile": "1rem"
                    },
                    "fontFamily": {
                        "headline-lg": ["Inter"],
                        "label-md": ["Inter"],
                        "headline-md": ["Inter"],
                        "headline-lg-mobile": ["Inter"],
                        "display-lg": ["Inter"],
                        "body-md": ["Inter"],
                        "body-lg": ["Inter"]
                    },
                    "fontSize": {
                        "headline-lg": ["24px", { "lineHeight": "32px", "letterSpacing": "-0.01em", "fontWeight": "600" }],
                        "label-md": ["12px", { "lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "500" }],
                        "headline-md": ["20px", { "lineHeight": "28px", "fontWeight": "600" }],
                        "headline-lg-mobile": ["20px", { "lineHeight": "28px", "fontWeight": "600" }],
                        "display-lg": ["36px", { "lineHeight": "44px", "letterSpacing": "-0.02em", "fontWeight": "600" }],
                        "body-md": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
                        "body-lg": ["16px", { "lineHeight": "24px", "fontWeight": "400" }]
                    }
                },
            },
        }
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #fdf8f8;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }

        .login-card-shadow {
            box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.03), 0px 1px 2px rgba(0, 0, 0, 0.06);
        }

        .grayscale-image {
            filter: grayscale(100%) contrast(1.1);
        }
    </style>
</head>

<body class="bg-background text-on-surface antialiased overflow-hidden">
    <%- include('../partials/authNav') %>
        <main class="flex min-h-screen">
            <!-- Left Side: Aesthetic Gray-Scale Section -->
            <section
                class="hidden md:flex md:w-1/2 lg:w-3/5 bg-surface-container relative items-center justify-center p-stack-lg overflow-hidden border-r border-outline">
                <!-- Minimal background pattern -->
                <div class="absolute inset-0 opacity-[0.4]"
                    style="background-image: linear-gradient(#E5E5E5 1px, transparent 1px), linear-gradient(90deg, #E5E5E5 1px, transparent 1px); background-size: 40px 40px;">
                </div>
                <div class="z-10 w-full max-w-2xl text-center px-12">
                    <div class="relative mb-stack-lg inline-block">
                        <img alt="Modern Smart City Interface"
                            class="w-full h-auto object-cover rounded-xl grayscale shadow-2xl border border-outline"
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBPTMB3srxSJKTeBhq3u42kfBIcsiKDsDiV8lfcAbE3_6hqYynSpeC5iFR-hovDqUunPR_Ri50NpHHuYjLJwq818yOj71LyFJfZmzQzx4xMAxJG2qSBAl5kEhN7LNuaHP1ct8RMH_x_GQTYHeFJb8UxCTVjcXOoMr9xgPIlvynMlPy5RYQ0-pthhsUsRAN2BFaCarqHDJDJ64YA9c_Ajv48InG8_d7ldJK-FVjneSG0EKIFkafzu5JZVq48w62txoL2ZszTBgZmCYlI" />
                        <div class="absolute inset-0 bg-primary/10 rounded-xl"></div>
                    </div>
                    <h1 class="text-display-lg font-extrabold text-primary mb-stack-sm tracking-tight">Modern Civic
                        Resolution</h1>
                    <p class="text-body-lg text-on-surface-variant max-w-lg mx-auto leading-relaxed">
                        Empowering citizens through transparent digital governance and administrative excellence.
                    </p>
                </div>
                <!-- Brand Anchor -->
                <div class="absolute bottom-10 left-10 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-3xl font-bold"
                        data-icon="account_balance">account_balance</span>
                    <span class="text-headline-md font-extrabold tracking-tighter text-primary">CivicResolve</span>
                </div>
            </section>
            <!-- Right Side: Login Form -->
            <section
                class="w-full lg:w-1/2 flex flex-col items-center justify-center p-margin-mobile md:p-margin-desktop bg-surface">
                <!-- Branding for Mobile -->
                <div class="lg:hidden flex flex-col items-center mb-stack-lg">
                    <span class="material-symbols-outlined text-[40px] text-primary mb-stack-xs">account_balance</span>
                    <h1 class="font-headline-lg text-headline-lg-mobile text-primary">CivicResolve</h1>
                </div>
                <div class="w-full max-max-w-md max-w-[440px]">
                    <div
                        class="bg-surface-container-lowest login-card-shadow rounded-xl p-8 md:p-10 border border-outline-variant/30">
                        <div class="mb-stack-lg">
                            <h2 class="font-headline-lg text-headline-lg text-primary mb-stack-xs">User Login</h2>
                            <p class="font-body-md text-body-md text-on-surface-variant">Access your dashboard to track
                                and
                                manage complaints.</p>
                        </div>
                        <form action="/api/auth/login" class="space-y-stack-md" method="POST">
                            <!-- Email Field -->
                            <div class="space-y-stack-xs">
                                <label
                                    class="block font-label-md text-label-md text-on-surface-variant uppercase tracking-wider"
                                    for="email">Email Address</label>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">alternate_email</span>
                                    <input
                                        class="w-full pl-10 pr-4 py-3 bg-surface border border-outline-variant rounded-lg focus:ring-1 focus:ring-primary focus:border-primary transition-all font-body-md text-on-surface outline-none placeholder:text-outline"
                                        id="email" name="email" placeholder="name@example.com" required=""
                                        type="email" />
                                </div>
                            </div>
                            <!-- Password Field -->
                            <div class="space-y-stack-xs">
                                <label
                                    class="block font-label-md text-label-md text-on-surface-variant uppercase tracking-wider"
                                    for="password">Password</label>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">lock</span>
                                    <input
                                        class="w-full pl-10 pr-12 py-3 bg-surface border border-outline-variant rounded-lg focus:ring-1 focus:ring-primary focus:border-primary transition-all font-body-md text-on-surface outline-none placeholder:text-outline"
                                        id="password" name="password" placeholder="••••••••" required=""
                                        type="password" />
                                    <button
                                        class="absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary transition-colors"
                                        type="button">
                                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                                    </button>
                                </div>
                            </div>
                            <!-- Options Row -->
                            <div class="flex items-center justify-between py-1">
                                <label class="flex items-center space-x-2 cursor-pointer group">
                                    <div class="relative flex items-center">
                                        <input
                                            class="peer h-4 w-4 rounded border-outline-variant text-primary focus:ring-0 cursor-pointer"
                                            type="checkbox" />
                                    </div>
                                    <span
                                        class="font-body-md text-body-md text-on-surface-variant group-hover:text-on-surface transition-colors">Remember
                                        Me</span>
                                </label>
                                <a class="font-body-md text-body-md text-primary font-medium hover:underline transition-all"
                                    href="#">Forgot Password?</a>
                            </div>
                            <!-- Primary CTA -->
                            <button
                                class="w-full py-3.5 bg-primary text-on-primary font-headline-md text-body-lg rounded-lg hover:bg-opacity-90 active:scale-[0.98] transition-all duration-150 flex items-center justify-center gap-2"
                                type="submit">
                                <span>Login</span>
                                <span class="material-symbols-outlined text-[20px]">login</span>
                            </button>

                            <!-- Divider -->
                            <div class="relative flex items-center py-4">
                                <div class="flex-grow border-t border-outline-variant"></div>
                                <span
                                    class="flex-shrink mx-4 font-label-md text-label-md text-outline uppercase tracking-widest">Or</span>
                                <div class="flex-grow border-t border-outline-variant"></div>
                            </div>
                            <!-- Social Login -->

                            <a class="w-full py-3.5 bg-primary text-on-primary font-headline-md text-body-lg rounded-lg hover:bg-opacity-90 active:scale-[0.98] transition-all duration-150 flex items-center justify-center gap-2"
                                type="submit" href="/login/admin">
                                <span>Admin login</span>
                                <span class="material-symbols-outlined text-[20px]">login</span>
                            </a>
                        </form>
                    </div>
                    <!-- Secondary Actions & Footer -->
                    <div class="mt-stack-lg text-center space-y-stack-md">
                        <p class="font-body-md text-body-md text-on-surface-variant">
                            Don't have an account?
                            <a class="text-primary font-semibold hover:underline" href="/register">Register</a>
                        </p>
                        <div class="pt-stack-md flex items-center justify-center gap-x-6">
                            <a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors"
                                href="#">Privacy Policy</a>
                            <a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors"
                                href="#">Terms of Service</a>
                            <a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors"
                                href="#">Help Center</a>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <%- include('../partials/authFooter') %>
            <!-- Micro-interaction: Input highlight & Click effect -->
            <script>
                document.querySelectorAll('input').forEach(input => {
                    input.addEventListener('focus', () => {
                        input.parentElement.querySelector('.material-symbols-outlined').style.color = '#171717';
                    });
                    input.addEventListener('blur', () => {
                        input.parentElement.querySelector('.material-symbols-outlined').style.color = '#444748';
                    });
                });

                // Toggle Password visibility logic
                const toggleBtn = document.querySelector('button .material-symbols-outlined[innerText="visibility"]');
                if (toggleBtn) {
                    let visible = false;
                    toggleBtn.parentElement.addEventListener('click', () => {
                        const passInput = document.getElementById('password');
                        visible = !visible;
                        passInput.type = visible ? 'text' : 'password';
                        toggleBtn.innerText = visible ? 'visibility_off' : 'visibility';
                    });
                }
            </script>
</body>

</html>