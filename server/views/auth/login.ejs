<div class="min-h-screen flex items-center justify-center bg-gray-100">

    <div class="w-full max-w-md bg-white rounded-2xl shadow-sm p-8">

        <div class="mb-8 text-center">
            <h1 class="text-3xl font-bold">
                Login
            </h1>

            <p class="text-gray-500 mt-2">
                Workplace Issue Tracking System
            </p>
        </div>

        <form action="/login" method="POST" class="space-y-5">

            <% if (typeof error !=="undefined" ) { %>

                <div class="mb-4 p-3 rounded-xl bg-red-100 text-red-700">
                    <%= error %>
                </div>

                <% } %>

                    <div>
                        <label class="block mb-2">
                            Email
                        </label>

                        <input type="email" name="email" required class="w-full border rounded-xl p-3"
                            placeholder="Enter email">
                    </div>

                    <div>
                        <label class="block mb-2">
                            Password
                        </label>

                        <input type="password" name="password" required class="w-full border rounded-xl p-3"
                            placeholder="Enter password">
                    </div>

                    <button type="submit" class="w-full bg-black text-white rounded-xl py-3">
                        Login
                    </button>

        </form>

    </div>

</div>