<div class="space-y-6">

  <div>
    <h1 class="text-3xl font-bold">
      Employees
    </h1>

    <p class="text-gray-500">
      Manage registered employees
    </p>
  </div>

  <div
    class="bg-white rounded-2xl shadow-sm overflow-hidden"
  >

    <table class="w-full">

      <thead
        class="bg-gray-50 border-b"
      >
        <tr>

          <th class="text-left p-4">
            Employee ID
          </th>

          <th class="text-left p-4">
            Name
          </th>

          <th class="text-left p-4">
            Email
          </th>

          <th class="text-left p-4">
            Department
          </th>

          <th class="text-left p-4">
            Role
          </th>

        </tr>
      </thead>

      <tbody>

        <% employees.forEach(employee => { %>

          <tr
            class="border-b hover:bg-gray-50"
          >

            <td class="p-4">
              <%= employee.employeeId %>
            </td>

            <td class="p-4">
              <%= employee.name %>
            </td>

            <td class="p-4">
              <%= employee.email %>
            </td>

            <td class="p-4">
              <%= employee.department %>
            </td>

            <td class="p-4">
              <%= employee.role %>
            </td>

          </tr>

        <% }) %>

      </tbody>

    </table>

  </div>

</div>