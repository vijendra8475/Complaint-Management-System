<div class="max-w-4xl mx-auto">

    <div class="mb-8">
        <h1 class="text-3xl font-bold">
            Create Complaint
        </h1>

        <p class="text-gray-500">
            Report a workplace issue
        </p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm p-8">

        <form action="/complaints/new" method="POST" class="space-y-6">

            <div>

                <label class="block mb-2 font-medium">
                    Title
                </label>

                <input type="text" name="title" required class="w-full border rounded-xl p-3"
                    placeholder="Enter complaint title" />

            </div>

            <div>

                <label class="block mb-2 font-medium">
                    Description
                </label>

                <textarea name="description" rows="6" required class="w-full border rounded-xl p-3"
                    placeholder="Describe the issue"></textarea>

            </div>

            <button type="submit" class="px-6 py-3 rounded-xl bg-black text-white">
                Submit Complaint
            </button>

        </form>

    </div>

</div>