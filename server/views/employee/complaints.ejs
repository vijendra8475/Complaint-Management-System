<div class="space-y-6">

  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-3xl font-bold">
        All Complaints
      </h1>

      <p class="text-gray-500">
        Manage and track all employee complaints
      </p>
    </div>
  </div>

  <div class="bg-white rounded-2xl shadow-sm overflow-hidden">

    <table class="w-full">

      <thead class="bg-gray-50 border-b">

        <tr>

          <th class="text-left p-4">
            Employee
          </th>

          <th class="text-left p-4">
            Title
          </th>

          <th class="text-left p-4">
            Category
          </th>

          <th class="text-left p-4">
            Priority
          </th>

          <th class="text-left p-4">
            Status
          </th>

          <th class="text-left p-4">
            Action
          </th>

        </tr>

      </thead>

      <tbody>

        <% complaints.forEach(complaint => { %>

          <tr class="border-b hover:bg-gray-50">

            <td class="p-4">
              <%= complaint.employee %>
            </td>

            <td class="p-4">
              <%= complaint.title %>
            </td>

            <td class="p-4">
              <%= complaint.category %>
            </td>

            <td class="p-4">
              <%= complaint.priority %>
            </td>

            <td class="p-4">

              <span
                class="px-3 py-1 rounded-full text-sm bg-gray-100"
              >
                <%= complaint.status %>
              </span>

            </td>

            <td class="p-4">

              <a
                href="/admin/complaints/<%= complaint._id %>"
                class="text-blue-600 hover:underline"
              >
                View
              </a>

            </td>

          </tr>

        <% }) %>

      </tbody>

    </table>

  </div>

</div>