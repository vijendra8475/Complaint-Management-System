<div class="max-w-4xl mx-auto">

  <div class="mb-8">
    <h1 class="text-3xl font-bold">
      Profile
    </h1>

    <p class="text-gray-500">
      Employee Information
    </p>
  </div>

  <div
    class="bg-white rounded-2xl shadow-sm p-8"
  >

    <div
      class="grid grid-cols-2 gap-6"
    >

      <div>
        <p class="text-gray-500">
          Employee ID
        </p>

        <p class="font-semibold">
          <%= employee.employeeId %>
        </p>
      </div>

      <div>
        <p class="text-gray-500">
          Name
        </p>

        <p class="font-semibold">
          <%= employee.name %>
        </p>
      </div>

      <div>
        <p class="text-gray-500">
          Email
        </p>

        <p class="font-semibold">
          <%= employee.email %>
        </p>
      </div>

      <div>
        <p class="text-gray-500">
          Department
        </p>

        <p class="font-semibold">
          <%= employee.department %>
        </p>
      </div>

      <div>
        <p class="text-gray-500">
          Designation
        </p>

        <p class="font-semibold">
          <%= employee.designation %>
        </p>
      </div>

      <div>
        <p class="text-gray-500">
          Role
        </p>

        <p class="font-semibold">
          <%= employee.role %>
        </p>
      </div>

    </div>

  </div>

</div>